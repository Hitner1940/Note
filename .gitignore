# Ignore device-specific UI layout and open tabs
.obsidian/workspace
.obsidian/workspace.json

# Ignore cache files generated by Obsidian or community plugins
.obsidian/cache/
.obsidian/graph.json

# OPTIONAL: Un-comment the line below if you use Obsidian Sync alongside Git
# .obsidian/sync/

# OPTIONAL: Un-comment the line below if you want to install plugins manually on each device
# .obsidian/plugins/
